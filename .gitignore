# Local config (users copy tools.example.json → tools.json)
config/tools.json

# Editor / OS junk
.DS_Store
.vscode/
.idea/
*.swp

# Logs
*.log

# Excalidraw working files (not published yet)
*.excalidraw

# Diagram drafts (not published yet)
docs/diagrams.md
docs/diagrams-preview.html

# Node / Python leftovers if contributors add tooling
node_modules/
__pycache__/
*.pyc
.venv/

# The plugin WRITES to .claude/sdlc/ in the *consuming* repo, not this one.
# Consuming repos should add .claude/sdlc/gates/ and .claude/sdlc/defects/
# to their own .gitignore if they don't want those tracked.
